# Copy this to .env and fill in your values

# From Discord Developer Portal > Your App > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# From Discord Developer Portal > Your App > General Information > Application ID
CLIENT_ID=your_application_id_here

# Optional: your Discord server ID for instant command registration during testing
# Remove or leave blank for global registration
GUILD_ID=your_guild_id_here
