# Copy this to .env and fill in your values

# From Discord Developer Portal > Your App > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# From Discord Developer Portal > Your App > General Information > Application ID
CLIENT_ID=your_application_id_here

# Optional: comma-separated list of Discord server IDs for instant command registration
# Remove or leave blank for global registration (takes up to 1 hour to propagate)
GUILD_ID=your_guild_id_here,another_guild_id_here

# Optional: comma-separated list of channel IDs where commands are allowed
# Leave blank to allow commands in all channels
ALLOWED_CHANNEL_IDS=your_channel_id_here,another_channel_id_here

# Optional: pin to a specific commit SHA from any2cards/worldhaven for data stability
# Leave blank to always use the latest master
WORLDHAVEN_REF=
