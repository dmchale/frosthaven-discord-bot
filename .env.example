# Copy this to .env and fill in your values

# From Discord Developer Portal > Your App > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# From Discord Developer Portal > Your App > General Information > Application ID
CLIENT_ID=your_application_id_here

# Optional: comma-separated list of Discord server IDs for instant command registration
# Remove or leave blank for global registration (takes up to 1 hour to propagate)
GUILD_ID=

# Optional: comma-separated list of channel IDs where commands are allowed
# Leave blank to allow commands in all channels
ALLOWED_CHANNEL_IDS=

# Optional: set to "true" to make all command replies public (posted to channel) by default
# When unset or empty, all replies are ephemeral (only visible to the invoking user)
# The per-command `public` option overrides this — subject to PUBLIC_ADMIN_IDS below
PUBLIC_BY_DEFAULT=

# Optional: comma-separated Discord user IDs allowed to post results publicly.
# Only meaningful when PUBLIC_BY_DEFAULT is unset or false.
#   Empty (default): nobody may override — all results are always ephemeral.
#   Populated: only listed users may pass `public: true` to post a result to the channel.
PUBLIC_ADMIN_IDS=

# Base URL for self-hosted item card images (no trailing slash).
# Item filenames from items.json are appended to this at display time.
# Example: https://raw.githubusercontent.com/you/frosthaven-discord-bot/main/images/items/frosthaven
ITEM_IMAGE_BASE=

# Base URL for self-hosted ability card images (no trailing slash).
# Ability card paths from ability-cards.json (CLASS/filename.jpeg) are appended to this at display time.
# Example: https://raw.githubusercontent.com/you/frosthaven-discord-bot/main/images/character-ability-cards/frosthaven
ABILITY_IMAGE_BASE=

# Base URL for self-hosted event card images (no trailing slash).
# Event image paths from events.json (type/filename.jpeg) are appended to this at display time.
# Example: https://raw.githubusercontent.com/you/frosthaven-discord-bot/main/images/events/frosthaven
EVENT_IMAGE_BASE=

# Optional: pin to a specific commit SHA from any2cards/worldhaven for data stability
# Only used by scripts/fetch-data.js, not the bot at runtime
WORLDHAVEN_REF=
